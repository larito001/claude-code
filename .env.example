# Anthropic-compatible endpoint. DeepSeek is the default development provider.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_API_KEY=replace-with-your-api-key

# Main and sub-agent model routing.
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash

# Optional user-data root. Defaults to ~/.claude-code-core-framework.
# FRAMEWORK_CONFIG_DIR=C:/path/to/framework-data

# Optional framework capabilities. Comma-separated.
# CLAUDE_CODE_FEATURES=PROACTIVE,COORDINATOR_MODE
# CLAUDE_CODE_DISABLE_FEATURES=QUICK_SEARCH
