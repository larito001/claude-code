{
  "name": "claude-code-core-framework",
  "version": "0.2.0",
  "description": "API-key-only Claude Code core framework for secondary development",
  "private": true,
  "type": "module",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/agentSdkTypes.d.ts",
  "exports": {
    ".": {
      "types": "./dist/sdk/agentSdkTypes.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun --env-file=.env run src/entrypoints/cli.tsx",
    "build": "bun run build:cli && bun run build:sdk",
    "build:cli": "bun build src/entrypoints/cli.tsx --outdir=dist --target=bun --sourcemap",
    "build:sdk": "bun build src/entrypoints/agentSdkTypes.ts --outfile=dist/sdk/index.js --target=bun --format=esm --external=@anthropic-ai/claude-agent-sdk --sourcemap=inline && bun x tsc -p tsconfig.sdk.json",
    "typecheck": "bun x tsc -p tsconfig.framework.json --noEmit",
    "typecheck:legacy": "bun x tsc --noEmit",
    "audit:comments": "bun run scripts/audit-src-comments.ts",
    "annotate:methods": "bun run scripts/annotate-src-methods.ts",
    "localize:comments": "bun --env-file=.env run scripts/localize-src-comments.ts",
    "smoke": "bun run scripts/smoke.ts",
    "smoke:api": "bun --env-file=.env run scripts/smoke-api.ts",
    "smoke:core": "bun run scripts/smoke-core.ts",
    "smoke:extensions": "bun run scripts/smoke-extensions.ts",
    "smoke:release": "bun run build && bun --env-file=.env run scripts/smoke-release.ts",
    "smoke:session": "bun --env-file=.env run scripts/smoke-session.ts",
    "smoke:ui": "bun run scripts/smoke-ui.ts",
    "smoke:all": "bun run check && bun run smoke:core && bun run smoke:extensions && bun run smoke:ui && bun run smoke:api && bun run smoke:session && bun run smoke:release",
    "check": "bun run typecheck && bun run build && bun run smoke",
    "config": "bun run config-ui/server.ts"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@anthropic-ai/bedrock-sdk": "^0.32.0",
    "@anthropic-ai/claude-agent-sdk": "0.2.114",
    "@anthropic-ai/foundry-sdk": "^0.4.0",
    "@anthropic-ai/mcpb": "^2.1.2",
    "@anthropic-ai/sandbox-runtime": "^0.0.44",
    "@anthropic-ai/sdk": "^0.80.0",
    "@anthropic-ai/vertex-sdk": "^0.19.0",
    "@aws-sdk/client-bedrock": "^3.1090.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-sts": "^3.1090.0",
    "@azure/identity": "^4.13.1",
    "@commander-js/extra-typings": "^14.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "ajv": "^8.18.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.14.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "cli-highlight": "^2.1.11",
    "code-excerpt": "^4.0.0",
    "diff": "^8.0.4",
    "emoji-regex": "^10.6.0",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.5.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^8.0.0",
    "ignore": "^7.0.5",
    "indent-string": "^5.0.0",
    "ink": "^6.8.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.23",
    "lru-cache": "^11.2.7",
    "marked": "^17.0.5",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "plist": "^5.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "sharp": "^0.35.3",
    "shell-quote": "^1.8.3",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "tree-kill": "^1.2.2",
    "turndown": "^7.2.4",
    "type-fest": "^5.5.0",
    "undici": "^7.24.6",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.20.0",
    "xss": "^1.0.15",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/diff": "^7.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/plist": "^3.0.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.28.0",
    "@types/semver": "^7.7.0",
    "@types/shell-quote": "^1.7.5",
    "@types/signal-exit": "^3.0.4",
    "@types/stack-utils": "^2.0.3",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "trustedDependencies": [
    "@anthropic-ai/sdk",
    "sharp"
  ]
}
